# ============================================================
# Agent Knowledge Platform - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=AgentKnowledgePlatform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# --- Database (PostgreSQL) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=agent_platform
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# --- Qdrant (Vector Database) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- LLM Provider ---
# Options: deepseek / qwen / ernie
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1

# --- Embedding Model ---
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=your_embedding_api_key_here

# --- JWT ---
JWT_SECRET_KEY=change-me-to-another-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- File Upload ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
